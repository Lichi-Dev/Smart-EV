# MongoDB connection string (include database name)
MONGO_URI=mongodb://localhost:27017/Smart_EV

# Server port
PORT=4000

# Allowed CORS origin (frontend URL — port 5173 for Next.js dev)
CLIENT_ORIGIN=http://localhost:5173

# GraphHopper API key (geocoding + routing) — get one at https://www.graphhopper.com/
GRAPHHOPPER_API_KEY=your_graphhopper_api_key
